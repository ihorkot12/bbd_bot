# ╔══════════════════════════════════════════════════════════════════════════╗
# ║          Black Bear Dojo Bot V2 — Шаблон змінних середовища            ║
# ║   Скопіюйте цей файл у .env та заповніть усі обов'язкові значення.     ║
# ║   НІКОЛИ не додавайте .env до git (перевірте .gitignore)!              ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── ОБОВ'ЯЗКОВО ───────────────────────────────────────────────────────────────

# Токен бота від @BotFather у Telegram (отримати: https://t.me/BotFather)
# НІКОЛИ не вставляйте реальний токен у код або README!
TELEGRAM_BOT_TOKEN=

# Telegram ID власника клубу (отримати у @userinfobot або /id у цьому боті)
# Власник завжди отримує найвищі права незалежно від таблиці ролей
OWNER_TELEGRAM_ID=329214126

# ── GOOGLE SHEETS ─────────────────────────────────────────────────────────────

# Шлях до JSON-файлу облікових даних Google Service Account
# Детально: https://docs.gspread.org/en/latest/oauth2.html#service-account
GOOGLE_CREDENTIALS_FILE=credentials.json
# Railway-friendly alternative: paste the full Google service account JSON.
# If this is set, GOOGLE_CREDENTIALS_FILE is ignored.
GOOGLE_CREDENTIALS_JSON=

# ID таблиці Google Sheets (Black Bear Dojo — реальна таблиця вже створена)
# Таблиця: https://docs.google.com/spreadsheets/d/101vNE0kgiKy-WfqYOKpjrgcWVtYtuceDP3xTAK9Mlrg/edit
SPREADSHEET_ID=101vNE0kgiKy-WfqYOKpjrgcWVtYtuceDP3xTAK9Mlrg

# ── GOOGLE FORM (реєстрація учасників) ───────────────────────────────────────

# ID Google Form для реєстрації учасників (вже створена)
# Форма: https://docs.google.com/forms/d/e/1FAIpQLSesT2y1vreDee-V90xP66GaTEPFibCXuGI9czsOK6iqg0HpYA/viewform
REGISTRATION_FORM_ID=1rdsZwpIY93fdXtd5e8-hnfn9Si7bt0fNtmKlfLlZCO8
REGISTRATION_FORM_URL=https://docs.google.com/forms/d/e/1FAIpQLSesT2y1vreDee-V90xP66GaTEPFibCXuGI9czsOK6iqg0HpYA/viewform
TRIAL_FORM_ID=1cgQPkWnNQwvnvtTc4GNUCXBjfedOBvnLe5jGXFD5ZiI
TRIAL_FORM_URL=https://docs.google.com/forms/d/e/1FAIpQLSc7hWokYpbwC8JnY-VlHgwEcJGsOPBz-xf0aQeepQDWMwHkMA/viewform

# Інтервал опитування нових відповідей форми (хвилини). Рекомендовано: 15-30
FORM_POLL_INTERVAL_MINUTES=60
SEED_TEMPLATES_ON_STARTUP=false

# ── РОЗКЛАД АВТОМАТИЧНИХ ДІЙ ─────────────────────────────────────────────────

# Дні місяця для нагадувань про оплату (через кому)
PAYMENT_REMINDER_DAYS=1,5,10

# Час нагадування тренеру про відвідуваність перед заняттям (формат HH:MM)
ATTENDANCE_REMINDER_TIME=09:00

# Час перевірки незакритих журналів (після цього часу — алерт власнику)
ATTENDANCE_DEADLINE_TIME=22:00

# Ранкова картка тренера (нагадування з кнопками на сьогоднішні групи)
COACH_MORNING_CARD_TIME=07:30

# Нагадування тренеру до старту заняття, хвилини через кому
ATTENDANCE_PRE_REMINDER_MINUTES=60,30

# Час надсилання щоденного дайджесту власнику
DIGEST_TIME=08:00

# ── ІНФОРМАЦІЯ ПРО КЛУБ ──────────────────────────────────────────────────────

CLUB_NAME=Black Bear Dojo
CLUB_ADDRESS=Київ, вул. Прикладна, 1
CLUB_PHONE=+380XXXXXXXXX
# Посилання на Google Maps (опціонально)
CLUB_MAPS_LINK=
# Сайт клубу (опціонально)
CLUB_WEBSITE=
# Текст про вартість (відображається у відповідь на /price)
CLUB_PRICE_TEXT=Місячний абонемент: уточнюйте у адміністратора
# Текст розкладу (відображається у відповідь на /schedule)
CLUB_SCHEDULE_TEXT=Пн/Ср/Пт 18:00–19:30, Сб 10:00–11:30

# ── ТЕХНІЧНІ НАЛАШТУВАННЯ ────────────────────────────────────────────────────

# Часовий пояс (обов'язково Europe/Kyiv для України)
TIMEZONE=Europe/Kyiv
PARENTS_CHANNEL_ID=-1003210332922
BIRTHDAY_CHECK_TIME=09:00

# Рівень логування: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Шлях до файлу логів (залиште порожнім — тільки консоль)
LOG_FILE=

# Режим без Google Sheets (для тестування без credentials, true/false)
DRY_RUN=false
